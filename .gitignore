# Swift package manager build artifacts
.build/
.swiftpm/
DerivedData/
Package.resolved

# macOS
.DS_Store
**/.DS_Store

# Xcode
xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# External X11 reference material — synced via Dropbox, not via git.
# Re-fetchable with reference/fetch.sh. (`reference` is a symlink on this
# Mac so the bare-name form matches; `reference/` would skip symlinks.)
reference
reference/

# Claude Code project settings symlink (lives in Dropbox; per-Mac setup).
.claude

# Local scratch / capture screenshots — file or dir, both excluded.
capture_screen_ui
capture_screen_ui/

# Cross-machine Claude Code memory now lives IN the git tree as
# .claude-memory/ — was previously gitignored and Dropbox-synced, which
# caused sync-delay friction and occasional conflict copies during
# desktop↔laptop hand-offs. Tracking it in git means a `git pull`
# brings memory along with code. Each Mac still needs the one-time
# symlink from ~/.claude/projects/-Users-...-X/memory → .claude-memory/
# (see "Cross-machine Claude memory" in CLAUDE.md).
