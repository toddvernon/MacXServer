# Swift package manager build artifacts
.build/
.swiftpm/
DerivedData/
Package.resolved

# macOS
.DS_Store
**/.DS_Store

# Xcode
xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# External X11 reference material — synced via Dropbox, not via git.
# Re-fetchable with reference/fetch.sh. (`reference` is a symlink on this
# Mac so the bare-name form matches; `reference/` would skip symlinks.)
reference
reference/

# Claude Code project settings symlink (lives in Dropbox; per-Mac setup).
.claude

# Local scratch / capture screenshots — file or dir, both excluded.
capture_screen_ui
capture_screen_ui/

# Cross-machine Claude Code memory lives in ~/Dropbox/dev/X/.claude-memory/
# (NOT the git tree). It was moved out of the tree for the public release
# so it never ships. Reached via the per-project memory symlink; see the
# preflight check in CLAUDE.local.md. Never re-track it here.
.claude-memory
.claude-memory/

# Project-personal Claude instructions (two-Mac setup, preflight, bio
# pointers). Public-safe project guidance lives in CLAUDE.md instead.
CLAUDE.local.md

# Personal capture connection config (real host). Use connection.example.json as a template.
connection.json
